# Shadow AI Discovery Engine Configuration

# ============================================================
# GCP Configuration
# ============================================================

# Mock mode (no GCP account needed) - DEFAULT
USE_MOCK_GCP=true
GCP_PROJECT_ID=mock-shadow-ai-project

# To use REAL GCP, change to:
# USE_MOCK_GCP=false
# GCP_PROJECT_ID=your-actual-project-id
# GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json

# ============================================================
# Database Configuration
# ============================================================

# SQLite (default, no setup needed)
DATABASE_URL=sqlite:///./shadow_ai.db

# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/shadow_ai

# ============================================================
# API Configuration
# ============================================================

API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# ============================================================
# Frontend Configuration
# ============================================================

# Frontend dev server URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ============================================================
# Logging (Optional)
# ============================================================

# LOG_LEVEL=INFO
# LOG_FILE=./logs/shadow_ai.log

# ============================================================
# Advanced Configuration (Optional)
# ============================================================

# Scan settings
# MAX_CONCURRENT_SCANS=5
# SCAN_TIMEOUT_SECONDS=300

# Cache settings
# ENABLE_CACHE=false
# CACHE_TTL_SECONDS=900

# API rate limiting
# RATE_LIMIT_ENABLED=false
# RATE_LIMIT_PER_MINUTE=100
